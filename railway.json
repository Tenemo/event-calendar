{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": [
      ".mvn/**",
      "Dockerfile",
      "mvnw",
      "pom.xml",
      "railway.json",
      "src/**"
    ]
  },
  "deploy": {
    "region": "europe-west4-drams3a",
    "numReplicas": 1,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "overlapSeconds": 0,
    "drainingSeconds": 30
  }
}
