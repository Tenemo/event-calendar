<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Keep broad, high-signal correctness, concurrency, and security analysis enabled. -->
    <Match>
        <Bug category="CORRECTNESS,MT_CORRECTNESS,SECURITY"/>
    </Match>

    <!-- Resource lifetime findings are classified outside SpotBugs' high-signal categories. -->
    <Match>
        <Bug pattern="OBL_UNSATISFIED_OBLIGATION,OBL_UNSATISFIED_OBLIGATION_EXCEPTION_EDGE,ODR_OPEN_DATABASE_RESOURCE,ODR_OPEN_DATABASE_RESOURCE_EXCEPTION_PATH,OS_OPEN_STREAM,OS_OPEN_STREAM_EXCEPTION_PATH"/>
    </Match>

    <!-- Ignored or misinterpreted return values frequently hide failed operations. -->
    <Match>
        <Bug pattern="RV_EXCEPTION_NOT_THROWN,RV_RETURN_VALUE_IGNORED,RV_RETURN_VALUE_IGNORED_BAD_PRACTICE,RV_RETURN_VALUE_IGNORED_INFERRED,RV_RETURN_VALUE_IGNORED_NO_SIDE_EFFECT,RV_RETURN_VALUE_OF_PUTIFABSENT_IGNORED"/>
    </Match>

    <!-- Retain actionable serialization and reflection hazards without CDI proxy false positives. -->
    <Match>
        <Bug pattern="REFLC_REFLECTION_MAY_INCREASE_ACCESSIBILITY_OF_CLASS,REFLF_REFLECTION_MAY_INCREASE_ACCESSIBILITY_OF_FIELD,SE_BAD_FIELD_INNER_CLASS,SE_BAD_FIELD_STORE,SE_INNER_CLASS,SE_METHOD_MUST_BE_PRIVATE,SE_NO_SERIALVERSIONID,SE_NO_SUITABLE_CONSTRUCTOR,SE_NO_SUITABLE_CONSTRUCTOR_FOR_EXTERNALIZATION,SE_NONFINAL_SERIALVERSIONID,SE_NONLONG_SERIALVERSIONID,SE_NONSTATIC_SERIALVERSIONID,SE_PREVENT_EXT_OBJ_OVERWRITE,SE_PRIVATE_READ_RESOLVE_NOT_INHERITED,SE_READ_RESOLVE_IS_STATIC,SE_READ_RESOLVE_MUST_RETURN_OBJECT,SE_TRANSIENT_FIELD_NOT_RESTORED"/>
    </Match>
</FindBugsFilter>
